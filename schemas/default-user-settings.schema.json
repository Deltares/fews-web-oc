{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "settings"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "settings": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "id",
          "value"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "value": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "boolean"
              }
            ]
          },
          "enabled": {
            "type": "boolean"
          },
          "favorite": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
